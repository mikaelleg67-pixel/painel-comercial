function doImport(){
  var mesEl=document.getElementById('imp-mes');
  var mes=mesEl.value==='outro'?document.getElementById('imp-mes2').value.trim():mesEl.value;
  var fonte=document.getElementById('imp-fonte').value;
  if(!mes||!fonte){logImp('⚠ Selecione o Mês e a Fonte antes de confirmar.',true);return;}
  function sfN(v){try{var f=parseFloat(String(v).replace(',','.'));return isNaN(f)?0:f;}catch(e){return 0;}}
  var added=0,upd=0,skip=0;
  impRows.forEach(function(row){
    function get(f,def){def=def||'';var i=gCI(f);return i>=0?String(row[i]||'').trim():def;}
    var neg=get('negociacao');
    if(!neg||neg==='NaN'){skip++;return;}
    var rec={
      mes:mes,fonte:fonte,
      ci:get('ci'),cliente:get('cliente'),data:get('data'),
      negociacao:neg,
      valor_pedido:sfN(row[gCI('valor_pedido')]),
      receita_liquida:sfN(row[gCI('receita_liquida')]),
      valor_mc:sfN(row[gCI('valor_mc')]),
      mc_atual:sfN(row[gCI('mc_atual')]),
      valor_recomp:sfN(row[gCI('valor_recomp')]),
      mc_recomp:sfN(row[gCI('mc_recomp')]),
      status:get('status'),
      coluna1:get('coluna1'),
      numped:get('numped'),
      valida:get('valida')
    };
    var ei=RD.records.findIndex(function(r){return r.negociacao===neg&&r.mes===mes&&r.fonte===fonte;});
    if(ei>=0){RD.records[ei]=rec;upd++;}else{RD.records.push(rec);added++;}
  });
  // Save and sync
  saveData();
  // Rebuild filters and update ALL tabs immediately
  buildF();
  applyF();
  logImp('✅ Importação concluída!\n✔ '+added+' negociações adicionadas · '+upd+' atualizadas · '+skip+' ignoradas\nMês: '+mes+' | Fonte: '+fonte+'\n\n🔄 Todos os gráficos e tabelas foram atualizados agora.');
  document.getElementById('imp-map').style.display='none';
  document.getElementById('f-imp').value='';
  impRows=[];
}


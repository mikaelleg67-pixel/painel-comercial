<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — Recomposição de Margem</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{--bg:#0f1117;--sur:#1a1d27;--sur2:#22263a;--bdr:#2e3350;--blue:#4f8ef7;--bl:#7ab3ff;--grn:#22c55e;--red:#ef4444;--yel:#f59e0b;--pur:#a855f7;--cyn:#06b6d4;--txt:#e2e8f0;--mu:#94a3b8;--dim:#64748b;--r:12px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--txt);font-family:'Segoe UI',system-ui,sans-serif;font-size:13px}
.hdr{background:linear-gradient(135deg,#1a1d27,#16213e);border-bottom:1px solid var(--bdr);padding:12px 22px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.hdr-l{display:flex;align-items:center;gap:12px}
.logo{width:34px;height:34px;background:linear-gradient(135deg,var(--blue),var(--pur));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:17px}
.hdr-t h1{font-size:16px;font-weight:700}.hdr-t p{font-size:11px;color:var(--mu)}
.btn{padding:7px 13px;border-radius:7px;border:none;cursor:pointer;font-size:12px;font-weight:600;display:flex;align-items:center;gap:5px;transition:.15s;white-space:nowrap}
.btn-p{background:var(--blue);color:#fff}.btn-p:hover{background:var(--bl)}
.btn-o{background:transparent;border:1px solid var(--bdr);color:var(--mu)}.btn-o:hover{border-color:var(--blue);color:var(--blue)}
.btn-sm{padding:5px 10px;font-size:11px}
.layout{display:flex;min-height:calc(100vh - 61px)}
.sb{background:var(--sur);border-right:1px solid var(--bdr);overflow-y:auto;transition:width .25s,min-width .25s;width:252px;min-width:252px}
.sb.closed{width:40px;min-width:40px}
.sb-in{padding:12px;width:252px}
.sb.closed .sb-in{opacity:0;pointer-events:none}
.sb-tog{width:100%;background:none;border:1px solid var(--bdr);border-radius:6px;color:var(--mu);padding:6px 8px;cursor:pointer;font-size:12px;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;transition:.15s}
.sb-tog:hover{border-color:var(--blue);color:var(--blue)}
.sb.closed .sb-tog{justify-content:center}
.sb-sec{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--dim);margin:13px 0 6px;font-weight:700}
.fl{margin-bottom:10px}.fl-l{font-size:11px;color:var(--mu);margin-bottom:4px}
.fi,.fs{width:100%;padding:7px 9px;background:var(--sur2);border:1px solid var(--bdr);border-radius:7px;color:var(--txt);font-size:12px;outline:none}
.fi:focus,.fs:focus{border-color:var(--blue)}.fs option{background:var(--sur2)}
.chk-g{display:flex;flex-direction:column;gap:4px;max-height:120px;overflow-y:auto}
.chk-i{display:flex;align-items:center;gap:6px;cursor:pointer;padding:3px 4px;border-radius:5px}
.chk-i:hover{background:var(--sur2)}.chk-i input[type=checkbox]{accent-color:var(--blue)}
.chk-i span{font-size:12px;color:var(--mu)}
.sdot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.rst{width:100%;padding:7px;background:var(--sur2);border:1px solid var(--bdr);border-radius:7px;color:var(--mu);font-size:12px;cursor:pointer;margin-top:6px}
.rst:hover{border-color:var(--red);color:var(--red)}
.main{flex:1;padding:18px;overflow-y:auto;min-width:0}
.tab-pane{display:none}.tab-pane.active{display:block}
.cef{background:linear-gradient(135deg,rgba(34,197,94,.15),rgba(34,197,94,.05));border:1.5px solid rgba(34,197,94,.4);border-radius:var(--r);padding:14px 18px;display:flex;align-items:center;gap:18px;margin-bottom:14px;position:relative;overflow:hidden}
.cef::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grn)}
.cef-i{font-size:28px;flex-shrink:0}.cef-b{flex:1}
.cef-l{font-size:10px;color:#86efac;text-transform:uppercase;letter-spacing:.7px;margin-bottom:2px}
.cef-v{font-size:24px;font-weight:800;color:#4ade80}.cef-s{font-size:11px;color:#86efac;margin-top:2px}
.cef-bd{display:inline-flex;align-items:center;gap:4px;background:rgba(34,197,94,.2);border:1px solid rgba(34,197,94,.4);border-radius:20px;padding:2px 9px;font-size:10px;font-weight:700;color:#4ade80;margin-top:5px}
.cef-r{text-align:right;flex-shrink:0}.cef-p{font-size:20px;font-weight:700;color:#4ade80}
.cg{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:16px}
.card{background:var(--sur);border:1px solid var(--bdr);border-radius:var(--r);padding:12px 14px;position:relative;overflow:hidden;transition:.15s}
.card:hover{transform:translateY(-2px);box-shadow:0 4px 24px rgba(0,0,0,.4)}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.card.blue::before{background:var(--blue)}.card.grn::before{background:var(--grn)}.card.red::before{background:var(--red)}.card.yel::before{background:var(--yel)}.card.pur::before{background:var(--pur)}.card.cyn::before{background:var(--cyn)}
.c-i{font-size:18px;margin-bottom:6px}.c-l{font-size:10px;color:var(--dim);margin-bottom:3px;text-transform:uppercase;letter-spacing:.5px;line-height:1.3}
.c-v{font-size:18px;font-weight:700;line-height:1.2}.c-s{font-size:10px;color:var(--mu);margin-top:2px}
.c-bd{position:absolute;top:10px;right:10px;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700}
.bok{background:rgba(34,197,94,.15);color:var(--grn)}.bpd{background:rgba(245,158,11,.15);color:var(--yel)}.bcn{background:rgba(239,68,68,.15);color:var(--red)}
.cg2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px}
.cg3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:16px}
.cc{background:var(--sur);border:1px solid var(--bdr);border-radius:var(--r);padding:14px}
.cc-h{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.cc-t{font-size:13px;font-weight:600}.cc-s{font-size:11px;color:var(--mu)}
.cw{position:relative;height:215px}.cw.t{height:275px}.cw.s{height:165px}
.cw canvas{display:block;width:100%!important;height:100%!important}
.pi-r{display:flex;justify-content:space-between;margin-bottom:3px}
.pb-bg{background:var(--sur2);border-radius:4px;height:8px;overflow:hidden}
.pb-f{height:100%;border-radius:4px;transition:width 1.2s ease}
.ts{background:var(--sur);border:1px solid var(--bdr);border-radius:var(--r);overflow:hidden;margin-bottom:16px}
.th{padding:12px 14px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.tsrch{display:flex;align-items:center;gap:7px;background:var(--sur2);border:1px solid var(--bdr);border-radius:7px;padding:6px 11px;min-width:190px}
.tsrch input{background:none;border:none;outline:none;color:var(--txt);font-size:12px;width:100%}
.tw{overflow-x:auto;max-height:420px;overflow-y:auto}
table{width:100%;border-collapse:collapse}
thead{position:sticky;top:0;background:var(--sur2);z-index:2}
th{padding:9px 10px;text-align:left;font-size:11px;font-weight:600;color:var(--mu);text-transform:uppercase;letter-spacing:.5px;cursor:pointer;white-space:nowrap;border-bottom:1px solid var(--bdr);user-select:none}
th:hover{color:var(--blue)}
td{padding:8px 10px;border-bottom:1px solid rgba(46,51,80,.4);font-size:12px;white-space:nowrap}
tr:hover td{background:var(--sur2)}
.sb2{padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700;text-transform:uppercase;display:inline-block}
.s-ok{background:rgba(34,197,94,.15);color:var(--grn)}.s-pd{background:rgba(245,158,11,.15);color:var(--yel)}.s-cn{background:rgba(239,68,68,.15);color:var(--red)}.s-ot{background:rgba(148,163,184,.1);color:var(--dim)}
.tf{padding:8px 14px;border-top:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px}
.pg{display:flex;gap:4px}
.pbt{padding:4px 8px;border-radius:5px;border:1px solid var(--bdr);background:none;color:var(--mu);font-size:11px;cursor:pointer}
.pbt.a{background:var(--blue);color:#fff;border-color:var(--blue)}.pbt:hover:not(.a){border-color:var(--blue);color:var(--blue)}
.hi td{background:rgba(79,142,247,.06)!important}
.rl{display:flex;flex-direction:column;gap:6px}
.ri{display:flex;align-items:center;gap:8px;padding:7px 9px;background:var(--sur2);border-radius:8px}
.ri:hover{background:#2a2f4a}
.rnum{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0}
.rn1{background:rgba(251,191,36,.2);color:#fbbf24}.rn2{background:rgba(148,163,184,.15);color:#94a3b8}.rn3{background:rgba(217,119,6,.15);color:#d97706}.rnn{background:var(--sur);color:var(--dim)}
.ri-info{flex:1;min-width:0}.ri-nm{font-size:12px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.ri-dt{font-size:10px;color:var(--mu)}
.ri-val{font-size:13px;font-weight:700;color:var(--blue);flex-shrink:0}
.tabs{display:flex;gap:2px;margin-bottom:14px;background:var(--sur);border:1px solid var(--bdr);border-radius:9px;padding:3px;flex-wrap:wrap;width:fit-content}
.tab{padding:5px 14px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:500;color:var(--mu);transition:.15s}
.tab.active{background:var(--blue);color:#fff}.tab:hover:not(.active){color:var(--txt)}
.srow{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:12px}
.sbox{background:var(--sur2);border-radius:8px;padding:9px 11px;text-align:center}
.sv{font-size:15px;font-weight:700;margin-bottom:2px}.sl{font-size:10px;color:var(--mu);text-transform:uppercase;letter-spacing:.4px;line-height:1.4}
.dzone{background:rgba(79,142,247,.07);border:1.5px dashed rgba(79,142,247,.4);border-radius:10px;padding:26px;text-align:center;cursor:pointer;transition:.2s;margin-bottom:16px}
.dzone:hover,.dzone.over{border-color:var(--blue);background:rgba(79,142,247,.12)}
.sync-toast{position:fixed;bottom:12px;right:12px;background:var(--sur);border:1px solid var(--bdr);border-radius:8px;padding:8px 14px;font-size:11px;color:var(--mu);z-index:300;opacity:0;transition:opacity .4s;pointer-events:none;box-shadow:0 4px 20px rgba(0,0,0,.4)}
.sync-toast.show{opacity:1}
#mdt tr{border-bottom:1px solid rgba(46,51,80,.4)}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:3px}::-webkit-scrollbar-thumb:hover{background:var(--blue)}
@media print{.sb,.hdr .btn,.tabs,.sync-toast{display:none!important}.main{padding:0}}
@media(max-width:900px){.cg2,.cg3{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="hdr">
  <div class="hdr-l">
    <div class="logo">📊</div>
    <div class="hdr-t"><h1>Recomposição de Margem</h1><p id="hdate">Carregando...</p></div>
  </div>
  <div style="display:flex;gap:8px">
    <button class="btn btn-o btn-sm" onclick="resetF()">↺ Resetar Filtros</button>
  </div>
</div>

<div class="layout">
<div class="sb" id="sb">
  <div class="sb-in">
    <button class="sb-tog" onclick="toggleSB()"><span id="sb-lbl">◀ Recolher</span></button>
    <div class="sb-sec">🔍 Busca</div>
    <div class="fl"><input class="fi" id="f-s" placeholder="Negociação, cliente, CI..." oninput="applyF()"></div>
    <div class="sb-sec">📅 Mês</div>
    <div class="fl"><div class="chk-g" id="f-mes"></div></div>
    <div class="sb-sec">📦 Fonte</div>
    <div class="fl"><div class="chk-g" id="f-fonte"></div></div>
    <div class="sb-sec">🏷 Status</div>
    <div class="fl"><div class="chk-g" id="f-status"></div></div>
    <div class="sb-sec">👤 CI</div>
    <div class="fl"><select class="fs" id="f-ci" onchange="applyF()"><option value="">Todos</option></select></div>
    <div class="sb-sec">💰 Valor Pedido (R$)</div>
    <div class="fl"><div class="fl-l">De</div><input class="fi" id="f-vp1" type="number" placeholder="0" oninput="applyF()"></div>
    <div class="fl"><div class="fl-l">Até</div><input class="fi" id="f-vp2" type="number" placeholder="sem limite" oninput="applyF()"></div>
    <div class="sb-sec">🎯 Valor Recomposto (R$)</div>
    <div class="fl"><div class="fl-l">De</div><input class="fi" id="f-vr1" type="number" placeholder="0" oninput="applyF()"></div>
    <div class="fl"><div class="fl-l">Até</div><input class="fi" id="f-vr2" type="number" placeholder="sem limite" oninput="applyF()"></div>
    <button class="rst" onclick="resetF()">✕ Limpar filtros</button>
  </div>
</div>

<div class="main">
  <div class="tabs">
    <div class="tab active" onclick="goTab('overview',this)">Visão Geral</div>
    <div class="tab" onclick="goTab('clientes',this)">Clientes</div>
    <div class="tab" onclick="goTab('negociacoes',this)">Negociações</div>
    <div class="tab" onclick="goTab('margem',this)">Margem</div>
    <div class="tab" onclick="goTab('verba',this)">Verba</div>
    <div class="tab" onclick="goTab('importar',this)">⬆ Importar</div>
  </div>

  <!-- VISÃO GERAL -->
  <div id="t-overview" class="tab-pane active">
    <div style="display:flex;justify-content:flex-end;gap:7px;margin-bottom:12px">
      <button class="btn btn-o btn-sm" onclick="doXls('overview')">⬇ Excel</button>
      <button class="btn btn-o btn-sm" onclick="doPdf('overview')">📄 PDF</button>
    </div>
    <div id="cef-wrap"></div>
    <div class="cg" id="kpi"></div>
    <div class="cg2">
      <div class="cc"><div class="cc-h"><span class="cc-t">📈 Evolução Mensal — Valor Recomposto</span></div><div class="cw"><canvas id="c-evol"></canvas></div></div>
      <div class="cc"><div class="cc-h"><span class="cc-t">🥧 Distribuição por Status</span></div><div class="cw"><canvas id="c-status"></canvas></div></div>
    </div>
    <div class="cg2">
      <div class="cc"><div class="cc-h"><span class="cc-t">📊 MC Atual vs MC Recomposição por Mês</span></div><div class="cw"><canvas id="c-mc"></canvas></div></div>
      <div class="cc"><div class="cc-h"><span class="cc-t">📦 Valor Recomposto por Fonte</span></div><div class="cw"><canvas id="c-fonte"></canvas></div></div>
    </div>
    <!-- TABELA -->
    <div class="ts">
      <div class="th">
        <div style="display:flex;align-items:center;gap:9px;flex-wrap:wrap">
          <span style="font-size:13px;font-weight:600">📋 Tabela de Negociações</span>
          <span class="bok" style="padding:2px 8px;border-radius:20px;font-size:10px" id="tbl-bdg">0</span>
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <div class="tsrch"><span>🔍</span><input id="tbl-q" placeholder="Pesquisar..." oninput="tSrch()"></div>
          <label style="font-size:11px;color:var(--mu);display:flex;align-items:center;gap:5px;cursor:pointer;white-space:nowrap">
            <input type="checkbox" id="tbl-asc" onchange="renderT()" style="accent-color:var(--blue)"> Mais antigo primeiro
          </label>
          <button class="btn btn-o btn-sm" onclick="doXls('table')">⬇ Excel</button>
          <button class="btn btn-o btn-sm" onclick="doPdf('table')">📄 PDF</button>
        </div>
      </div>
      <div class="tw">
        <table><thead><tr>
          <th onclick="srtT(0)">Mês ↕</th>
          <th onclick="srtT(1)">Fonte ↕</th>
          <th onclick="srtT(2)">CI ↕</th>
          <th onclick="srtT(3)">Cliente ↕</th>
          <th onclick="srtT(4)">Data ↕</th>
          <th onclick="srtT(5)">Negociação ↕</th>
          <th onclick="srtT(6)">Valor Pedido ↕</th>
          <th onclick="srtT(7)">Receita Líquida ↕</th>
          <th onclick="srtT(8)">Valor MC ↕</th>
          <th onclick="srtT(9)">MC Atual ↕</th>
          <th onclick="srtT(10)">Valor Recomp ↕</th>
          <th onclick="srtT(11)">MC Recomp ↕</th>
          <th onclick="srtT(12)">Status ↕</th>
          <th onclick="srtT(13)">Coluna1 ↕</th>
          <th onclick="srtT(14)">NUMPED ↕</th>
          <th onclick="srtT(15)">VALIDA ↕</th>
          <th style="color:#4ade80">✅ Efetivo</th>
        </tr></thead><tbody id="tbl-body"></tbody></table>
      </div>
      <div class="tf"><span style="font-size:11px;color:var(--dim)" id="tbl-info"></span><div class="pg" id="tbl-pg"></div></div>
    </div>
  </div>

  <!-- CLIENTES -->
  <div id="t-clientes" class="tab-pane">
    <div style="display:flex;justify-content:flex-end;gap:7px;margin-bottom:12px">
      <button class="btn btn-o btn-sm" onclick="doXls('clientes')">⬇ Excel</button>
      <button class="btn btn-o btn-sm" onclick="doPdf('clientes')">📄 PDF</button>
    </div>
    <div class="cg2">
      <div class="cc"><div class="cc-h"><span class="cc-t">🏆 Top 10 — Maior Valor Recomposto</span></div><div class="cw t"><canvas id="c-tcli"></canvas></div></div>
      <div class="cc"><div class="cc-h"><span class="cc-t">💸 Top 10 — Maior Consumo de Verba</span></div><div class="cw t"><canvas id="c-tverba"></canvas></div></div>
    </div>
    <div class="cc"><div class="cc-h"><span class="cc-t">🥇 Ranking de Clientes</span></div><div class="rl" id="rank-cli"></div></div>
  </div>

  <!-- NEGOCIAÇÕES -->
  <div id="t-negociacoes" class="tab-pane">
    <div style="display:flex;justify-content:flex-end;gap:7px;margin-bottom:12px">
      <button class="btn btn-o btn-sm" onclick="doXls('negociacoes')">⬇ Excel</button>
      <button class="btn btn-o btn-sm" onclick="doPdf('negociacoes')">📄 PDF</button>
    </div>
    <div class="cg2">
      <div class="cc"><div class="cc-h"><span class="cc-t">🏆 Top 10 Maiores Valores a Recompor</span></div><div class="cw t"><canvas id="c-tnegs"></canvas></div></div>
      <div class="cc"><div class="cc-h"><span class="cc-t">📊 Estatísticas</span></div><div id="extra-stats" style="padding-top:4px"></div></div>
    </div>
    <div class="cc"><div class="cc-h"><span class="cc-t">🥇 Ranking — Maior Impacto Financeiro</span></div><div class="rl" id="rank-neg"></div></div>
  </div>

  <!-- MARGEM -->
  <div id="t-margem" class="tab-pane">
    <div style="display:flex;justify-content:flex-end;gap:7px;margin-bottom:12px">
      <button class="btn btn-o btn-sm" onclick="doXls('margem')">⬇ Excel</button>
      <button class="btn btn-o btn-sm" onclick="doPdf('margem')">📄 PDF</button>
    </div>
    <div id="m-cards" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:10px;margin-bottom:14px"></div>
    <div class="cg2">
      <div class="cc"><div class="cc-h"><span class="cc-t">📊 MC Atual vs Recomposição</span><span class="cc-s">Até 40 válidas</span></div><div class="cw t"><canvas id="c-mc2"></canvas></div></div>
      <div class="cc"><div class="cc-h"><span class="cc-t">📈 Evolução da Margem Média por Mês</span></div><div class="cw t"><canvas id="c-mcavg"></canvas></div></div>
    </div>
    <div class="cg2" style="margin-bottom:14px">
      <div class="cc"><div class="cc-h"><span class="cc-t">🔍 Distribuição de MC Atual</span></div><div class="cw"><canvas id="c-mcdist"></canvas></div></div>
      <div class="cc"><div class="cc-h"><span class="cc-t">📉 Ganho de Margem por Mês</span></div><div class="cw"><canvas id="c-mcganho"></canvas></div></div>
    </div>
    <div class="cc" style="margin-bottom:14px">
      <div class="cc-h"><span class="cc-t">🔢 Detalhamento por Negociação (válidas)</span></div>
      <div style="overflow-x:auto;max-height:300px;overflow-y:auto">
        <table style="width:100%;border-collapse:collapse" id="mdt">
          <thead style="position:sticky;top:0;background:#22263a">
            <tr>
              <th style="padding:7px 10px;font-size:11px;color:var(--mu);text-align:left;border-bottom:1px solid var(--bdr)">Negociação</th>
              <th style="padding:7px 10px;font-size:11px;color:var(--mu);border-bottom:1px solid var(--bdr)">Mês</th>
              <th style="padding:7px 10px;font-size:11px;color:#ef4444;text-align:right;border-bottom:1px solid var(--bdr)">MC Atual</th>
              <th style="padding:7px 10px;font-size:11px;color:#22c55e;text-align:right;border-bottom:1px solid var(--bdr)">MC Recomp.</th>

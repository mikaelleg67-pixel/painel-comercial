var FLDS={negociacao:'Negociação (Cód.)',ci:'CI',cliente:'Cliente',data:'Data',valor_pedido:'Valor Pedido',receita_liquida:'Receita Líquida',valor_mc:'Valor MC',mc_atual:'MC Atual',valor_recomp:'Valor a Recompor',mc_recomp:'MC Recomposta',status:'Status',coluna1:'Coluna1',numped:'NUMPED',valida:'VALIDA'};

function doDrop(e){var f=e.dataTransfer.files[0];if(f)readFile({target:{files:[f]}});}

function readFile(e){
  var file=e.target.files[0];if(!file)return;
  logImp('📂 Lendo: '+file.name+'...');
  var reader=new FileReader();
  reader.onload=function(ev){
    try{
      var rows,nm=file.name.toLowerCase();
      if(nm.indexOf('.csv')>=0){
        var txt=ev.target.result;
        var lines=txt.split(/\r?\n/).filter(function(l){return l.trim();});
        var sep=lines[0].indexOf(';')>=0?';':(lines[0].indexOf('\t')>=0?'\t':',');
        rows=lines.map(function(l){return l.split(sep).map(function(c){return c.trim().replace(/^"|"$/g,'');});});
      } else {
        var wb=XLSX.read(ev.target.result,{type:'array',cellDates:true});
        var ws=wb.Sheets[wb.SheetNames[0]];
        rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:'',raw:false,dateNF:'YYYY-MM-DD'});
      }
      // Find header: first row with 3+ text cells (non-numeric, reasonable length)
      var hIdx=0;
      for(var i=0;i<Math.min(10,rows.length);i++){
        var tc=rows[i].filter(function(c){return c&&isNaN(Number(c))&&String(c).trim().length>1&&String(c).trim().length<50;});
        if(tc.length>=3){hIdx=i;break;}
      }
      impRows=rows.slice(hIdx+1).filter(function(r){return r.some(function(c){return String(c).trim();});});
      buildMap(rows[hIdx].map(function(h){return String(h).trim();}));
      logImp('✅ Arquivo lido! '+impRows.length+' linhas de dados detectadas (cabeçalho linha '+(hIdx+1)+').');
    }catch(err){logImp('❌ Erro ao ler arquivo: '+err.message,true);}
  };
  if(file.name.toLowerCase().indexOf('.csv')>=0)reader.readAsText(file,'UTF-8');
  else reader.readAsArrayBuffer(file);
}

function buildMap(cols){
  impCols=cols;
  document.getElementById('imp-map').style.display='block';
  document.getElementById('map-grid').innerHTML=Object.entries(FLDS).map(function(e){
    var k=e[0],lbl=e[1];
    return '<div><div class="fl-l">'+lbl+'</div><select class="fs" id="mp-'+k+'"><option value="">— Ignorar —</option>'+
      cols.map(function(h,i){return '<option value="'+i+'"'+(aMatch(h,k)?' selected':'')+'>'+(h||'(col '+(i+1)+')')+'</option>';}).join('')+'</select></div>';
  }).join('');
  document.getElementById('map-grid').onchange=updPrev;
  updPrev();
}

function aMatch(h,field){
  var hl=h.toLowerCase().replace(/[^a-z0-9 ]/g,'');
  var mp={
    negociacao:['neg','cod neg','negociacao'],
    ci:['ci','cod ci'],
    cliente:['cliente','razao'],
    data:['data neg','data negoc','date'],
    valor_pedido:['valor pedido','vl pedido'],
    receita_liquida:['receita liquida','receita liq','rec liq'],
    valor_mc:['valor mc','vl mc'],
    mc_atual:['mc atual','mc realizada','mc real','realizada','mc atua'],
    valor_recomp:['valor a recompor','vl recomp','valor recomp'],
    mc_recomp:['mc recomposta','mc recomp'],
    status:['status','situacao'],
    coluna1:['coluna1','coluna 1'],
    numped:['numped','num ped','numero pedido'],
    valida:['valida','valid']
  };
  return (mp[field]||[]).some(function(k){return hl.indexOf(k)>=0;});
}

function gCI(f){var el=document.getElementById('mp-'+f);return el&&el.value!==''?parseInt(el.value):-1;}

function updPrev(){

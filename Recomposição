// ===== SYNC =====
function initSync(){
  try{var s=localStorage.getItem(SK);if(s){var d=JSON.parse(s);if(d&&d.records&&d.records.length>0)RD=d;}}catch(e){}
  try{
    bc=new BroadcastChannel('recomp_'+SK);
    bc.onmessage=function(e){
      if(e.data&&e.data.t==='upd'){
        RD=e.data.d;
        buildF();applyF();
        toast('🔄 Dashboard atualizado por outro usuário');
      }
    };
  }catch(e){}
  setInterval(function(){
    try{
      var s=localStorage.getItem(SK);
      if(s){var d=JSON.parse(s);if(d&&d._ts&&RD._ts&&d._ts!==RD._ts){RD=d;buildF();applyF();toast('🔄 Dados atualizados');}}
    }catch(e){}
  },3000);
}

function saveData(){
  try{
    RD._ts=Date.now();
    localStorage.setItem(SK,JSON.stringify(RD));
    if(bc)bc.postMessage({t:'upd',d:RD});
    toast('✅ Salvo e sincronizado');
  }catch(e){console.warn(e);}
}

var toastTO=null;

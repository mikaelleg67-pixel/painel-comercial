function applyF(){
  var srch=(document.getElementById('f-s').value||'').toLowerCase();
  var selM=Array.from(document.querySelectorAll('[data-g="mes"]:checked')).map(function(e){return e.value;});
  var selF=Array.from(document.querySelectorAll('[data-g="fonte"]:checked')).map(function(e){return e.value;});
  var selS=Array.from(document.querySelectorAll('[data-g="status"]:checked')).map(function(e){return e.value;});
  var selCI=document.getElementById('f-ci').value;
  var vp1=parseFloat(document.getElementById('f-vp1').value)||0;
  var vp2=parseFloat(document.getElementById('f-vp2').value)||Infinity;
  var vr1=parseFloat(document.getElementById('f-vr1').value)||0;
  var vr2=parseFloat(document.getElementById('f-vr2').value)||Infinity;
  FD=RD.records.filter(function(r){
    if(selM.indexOf(r.mes)<0)return false;
    if(selF.indexOf(normF(r.fonte))<0)return false;
    if(selS.indexOf(nSt(r.status))<0)return false;
    if(selCI&&r.ci!==selCI)return false;
    if(r.valor_pedido<vp1||r.valor_pedido>vp2)return false;
    if(r.valor_recomp<vr1||r.valor_recomp>vr2)return false;
    if(srch){var h=(r.negociacao+r.cliente+r.ci+r.status+r.mes+r.fonte+r.numped+r.valida).toLowerCase();if(h.indexOf(srch)<0)return false;}
    return true;
  });
  curPg=1;
  updAll();
}

function resetF(){
  document.getElementById('f-s').value='';
  document.querySelectorAll('[data-g]').forEach(function(e){e.checked=true;});
  document.getElementById('f-ci').value='';
  ['f-vp1','f-vp2','f-vr1','f-vr2'].forEach(function(id){document.getElementById(id).value='';});
  applyF();
}

// ===== TAB =====
function goTab(id,el){
  document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});
  el.classList.add('active');
  document.querySelectorAll('.tab-pane').forEach(function(p){p.classList.remove('active');});
  document.getElementById('t-'+id).classList.add('active');
  activeTab=id;
  requestAnimationFrame(function(){requestAnimationFrame(function(){renderTab(id);});});
}

function renderTab(id){
  if(id==='overview')updOverview();

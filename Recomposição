function normF(f){return (f||'').indexOf('VERBA ANIBAL')>=0?'VERBA ANIBAL':(f||'');}

function nSt(s){
  if(!s)return 'OUTROS';
  var u=s.toUpperCase().trim();
  if(u==='OK'||u==='MC OK'||u.indexOf('FINALIZ')>=0)return 'OK';
  if(u==='EM PROCESSO'||u.indexOf('APROVA')>=0)return 'EM PROCESSO';
  if(u.indexOf('CANCEL')>=0||u.indexOf('NAO FECHOU')>=0||u.indexOf('NÃO FECHOU')>=0)return 'CANCELADO';
  if(u.indexOf('REPROV')>=0)return 'REPROVADA';
  if(u.indexOf('EXPIR')>=0)return 'EXPIRADO';
  if(u.indexOf('REINIC')>=0||u.indexOf('SUBSTIT')>=0||u.indexOf('SUBIST')>=0)return 'REINICIADA/SUBST.';
  return 'OUTROS';
}
function isEf(s){var u=(s||'').toUpperCase().trim();return u==='OK'||u==='MC OK'||u.indexOf('FINALIZ')>=0;}
function isEx(s){return ['REPROVADA','EXPIRADO','REINICIADA/SUBST.','OUTROS','CANCELADO'].indexOf(nSt(s))>=0;}
function sCls(s){var n=nSt(s);if(n==='OK')return 's-ok';if(n==='EM PROCESSO')return 's-pd';if(n==='CANCELADO'||n==='REPROVADA')return 's-cn';return 's-ot';}
